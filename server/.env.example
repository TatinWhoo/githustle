# Server
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# Local PostgreSQL
DATABASE_URL=postgresql://githustle_user:password@localhost:5432/githustle_dev

# Supabase (Transaction Pooler — port 6543)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-xx.pooler.supabase.com:6543/postgres

# Redis
REDIS_URL=

# JWT
JWT_ACCESS_SECRET=
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# Password Hashing
BCRYPT_SALT_ROUNDS=12

# Account Lockout 
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Email Verification
EMAIL_VERIFY_EXPIRES_HOURS=24

# Email
RESEND_API_KEY=
EMAIL_FROM=

# reCAPTCHA
RECAPTCHA_SECRET_KEY=

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
PORTFOLIO_IMAGE_MAX_SIZE_MB=8
PUBLIC_API_URL=http://localhost:4000
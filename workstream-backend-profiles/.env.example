# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workstream

# ── JWT (access tokens only — refresh tokens are opaque, not JWTs) ──
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_string_32+chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=7

# ── Password hashing ──────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Account lockout ───────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Email verification ────────────────────────────────────
EMAIL_VERIFY_EXPIRES_HOURS=24

# ── SMTP — leave blank in dev; emails will print to the console instead ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=WorkStream <no-reply@workstream.dev>

# ── File uploads ──────────────────────────────────────────
# Local disk storage for now. In production this would point at S3 or
# similar object storage instead — see the comment in utils/fileStorage.js.
UPLOAD_DIR=uploads
AVATAR_MAX_SIZE_MB=5
PORTFOLIO_IMAGE_MAX_SIZE_MB=8
PUBLIC_API_URL=http://localhost:4000
